 //
-// The graph builder is in place and matches the MLX reference; what this
-// stub currently does NOT do is run the builder K times through the scheduler
-// and read back logits. That requires adding a new llm_graph_type for
-// MTP-only forward passes plus a small allocator loop in llama_context.
-// Until that lands, the entry point returns a diagnostic so downstream
-// callers can detect whether MTP is available and fall back to stock decode.
-//
-// TODO(mtp): wire up through process_ubatch with LLM_GRAPH_TYPE_MTP.
-//
-// Status (Stage 3 partial):
-//   * The graph builder llm_build_qwen3next::build_mtp_head() is implemented
-//     and matches the MLX reference (see src/models/qwen3next.cpp).
-//   * MTP weights load via the NextN tensor path in llama-model.cpp.
-//   * The post-output-norm hidden state of the last decoded token is now
-//     captured into ctx->mtp_prev_hidden after every successful main decode
-//     (see the t_embd_for_mtp block above), so the input the MTP head needs
-//     is available host-side and ready to be uploaded into a draft graph.
-//   * LLM_GRAPH_TYPE_MTP has been added to llm_graph_type.
-//
-// What's still missing for end-to-end execution:
-//   1. A constructor branch in llm_build_qwen3next::llm_build_qwen3next()
-//      keyed on params.gtype == LLM_GRAPH_TYPE_MTP that, instead of building
-//      the full forward pass, allocates two input tensors
-//      (prev_hidden, tok_embed), copies ctx->mtp_prev_hidden and the
-//      embedding row for `last_token` into them, calls build_mtp_head() once,
-//      and writes the resulting logits into res->t_logits.
-//   2. A small llama_context helper that builds an llm_graph_params with
-//      gtype=LLM_GRAPH_TYPE_MTP and a synthetic 1-token ubatch, dispatches
-//      it through ggml_backend_sched_graph_compute_async, and pulls the
-//      logits back into a host buffer.
-//   3. A K-step loop here that, after each step, argmax-samples a token,
-//      writes it to out_tokens[i], optionally writes the full row into
-//      out_logits, and substitutes the MTP layer's output hidden state
-//      (returned via build_mtp_head's out_hidden) for prev_hidden on the
-//      next iteration. This mirrors MTPDraftHead.draft() in the MLX
-//      reference (~/mlx-fork/fused_gdn.py).
-//
-// Until (1) and (2) land, this entry point validates inputs, confirms the
-// hidden-state cache is populated, and returns -4 ("graph compute path not
-// yet wired") so callers cleanly fall back to plain autoregressive decode.
+// Correctness note: this implementation re-uses ctx->mtp_prev_hidden as the
+// previous-step hidden across all K draft steps rather than feeding the MTP
+// layer's own output hidden forward. This matches what dense Qwen 3.5 MTP
+// (PR #20700) does for chained drafting and is the conservative baseline; a
+// follow-up can read the MTP head's pre-norm hidden back from the graph and
+// substitute it for prev_hidden on the next iteration.
+
+int32_t llama_context::mtp_graph_compute(llama_token seed_token, float * out_logits, int64_t n_vocab) {
+    if (!gf_res_mtp) {
+        return -4;
+    }
+
+    // Build a one-token ubatch backed by stack-allocated arrays. Only the
+    // fields read by qwen3next's MTP path matter (token, n_tokens, output);
+    // the rest are zeroed for safety.
+    llama_token  tok          = seed_token;
+    llama_pos    pos          = 0;
+    int32_t      n_seq_id_arr = 1;
+    llama_seq_id seq_id_val   = 0;
+    llama_seq_id * seq_id_ptr = &seq_id_val;
+    llama_seq_id seq_id_unq   = 0;
+    int8_t       output_flag  = 1;
+
+    int32_t seq_idx_arr[LLAMA_MAX_SEQ];
+    for (int i = 0; i < LLAMA_MAX_SEQ; ++i) seq_idx_arr[i] = -1;
+    seq_idx_arr[0] = 0;
+
+    llama_ubatch ubatch = {};
+    ubatch.b_equal_seqs = 1;
+    ubatch.n_tokens     = 1;
+    ubatch.n_seq_tokens = 1;
+    ubatch.n_seqs       = 1;
+    ubatch.n_seqs_unq   = 1;
+    ubatch.n_pos        = 1;
+    ubatch.token        = &tok;
+    ubatch.embd         = nullptr;
+    ubatch.pos          = &pos;
+    ubatch.n_seq_id     = &n_seq_id_arr;
+    ubatch.seq_id       = &seq_id_ptr;
+    ubatch.seq_id_unq   = &seq_id_unq;
+    ubatch.seq_idx      = seq_idx_arr;
+    ubatch.output       = &output_flag;
+
+    // Snapshot/restore n_outputs since graph_params reads it via this->n_outputs.
+    const uint32_t saved_n_outputs = this->n_outputs;
+    this->n_outputs = 1;
+
+    auto * res = gf_res_mtp.get();
+    res->reset();
+
+    // Build params manually so we can target gf_res_mtp instead of gf_res_prev.
+    llm_graph_params gparams = {
+        /*.arch        =*/ model.arch,
+        /*.hparams     =*/ model.hparams,
+        /*.cparams     =*/ cparams,
+        /*.ubatch      =*/ ubatch,
+        /*.gtype       =*/ LLM_GRAPH_TYPE_MTP,
+        /*.sched       =*/ sched.get(),
+        /*.backend_cpu =*/ backend_cpu,
+        /*.cvec        =*/ cvec.get(),
+        /*.loras       =*/ loras.get(),
+        /*.mctx        =*/ nullptr,
+        /*.cross       =*/ &cross,
+        /*.samplers    =*/ {},
+        /*.n_outputs   =*/ 1,
+        /*.cb          =*/ graph_get_cb(),
+        /*.res         =*/ res,
+    };
+
+    ggml_backend_sched_reset(sched.get());
+
+    ggml_cgraph * gf = model.build_graph(gparams);
+    if (!gf) {
+        this->n_outputs = saved_n_outputs;
+        LLAMA_LOG_ERROR("%s: failed to build MTP graph\n", __func__);
+        return -4;
+    }
+
+    if (!ggml_backend_sched_alloc_graph(sched.get(), gf)) {
+        this->n_outputs = saved_n_outputs;
+        LLAMA_LOG_ERROR("%s: failed to allocate MTP graph\n", __func__);
+        return -4;
+    }
+
+    // Set token-embedding input via the registered llm_graph_input_embd callback.
+    res->set_inputs(&ubatch);
+
+    // Upload prev_hidden host buffer into the MTP graph input tensor.
+    if (res->t_mtp_prev_hidden_in == nullptr) {
+        this->n_outputs = saved_n_outputs;
+        LLAMA_LOG_ERROR("%s: MTP graph did not register a prev_hidden input tensor\n", __func__);
+        return -4;
+    }
+    {
+        const size_t want_bytes = ggml_nbytes(res->t_mtp_prev_hidden_in);
+        const size_t have_bytes = mtp_prev_hidden.size() * sizeof(float);
+        if (have_bytes < want_bytes) {
+            this->n_outputs = saved_n_outputs;
+            LLAMA_LOG_ERROR("%s: MTP prev_hidden buffer too small: have %zu have_bytes vs want %zu\n",
+                    __func__, have_bytes, want_bytes);
+            return -4;
+        }
+        ggml_backend_tensor_set(res->t_mtp_prev_hidden_in, mtp_prev_hidden.data(), 0, want_bytes);
+    }
+
+    // Upload the RoPE position-zero input (a single int32 zero).
+    if (res->t_mtp_pos_zero_in != nullptr) {
+        const int32_t zero = 0;
+        ggml_backend_tensor_set(res->t_mtp_pos_zero_in, &zero, 0, sizeof(zero));
+    }
+
+    const auto status = graph_compute(gf, /*batched=*/false);
+    if (status != GGML_STATUS_SUCCESS) {
+        this->n_outputs = saved_n_outputs;
+        LLAMA_LOG_ERROR("%s: MTP graph compute failed, status = %d\n", __func__, status);
+        return -4;
+    }
+
+    // Pull logits back to host.
+    auto * t_logits = res->get_logits();
+    if (t_logits == nullptr) {
+        this->n_outputs = saved_n_outputs;
+        LLAMA_LOG_ERROR("%s: MTP graph produced no logits tensor\n", __func__);
+        return -4;
+    }
+
+    const int64_t produced_vocab = t_logits->ne[0];
+    if (produced_vocab != n_vocab) {
+        LLAMA_LOG_WARN("%s: MTP logits n_vocab mismatch (graph=%lld, expected=%lld)\n",
+                __func__, (long long) produced_vocab, (long long) n_vocab);
+    }
+    const int64_t copy_vocab = std::min<int64_t>(produced_vocab, n_vocab);
+
+    ggml_backend_t backend_res = ggml_backend_sched_get_tensor_backend(sched.get(), t_logits);
+    if (backend_res == nullptr) {
+        this->n_outputs = saved_n_outputs;
+        LLAMA_LOG_ERROR("%s: MTP logits tensor has no backend\n", __func__);
+        return -4;
+    }
+    ggml_backend_tensor_get_async(backend_res, t_logits, out_logits, 0, copy_vocab * sizeof(float));
+    ggml_backend_sched_synchronize(sched.get());
+
+    this->n_outputs = saved_n_outputs;
+
+    // The next main decode will rebuild its own graph in gf_res_prev — our
+    // separate gf_res_mtp keeps state isolated. We still reset the scheduler
+    // so the next call to process_ubatch starts cleanly.
+    ggml_backend_sched_reset(sched.get());
+
+    return 0;
+}
+
 int32_t llama_mtp_draft(
         struct llama_context * ctx,
                  llama_token   last_token,
                      int32_t   n_draft,
                  llama_token * out_tokens,
                        float * out_logits) {
-    GGML_UNUSED(last_token);
-    GGML_UNUSED(out_logits);
-
     if (ctx == nullptr || out_tokens == nullptr || n_draft <= 0) {
         return -2;
     }
@@ -3599,9 +3714,50 @@ int32_t llama_mtp_draft(
         return -3;
     }
 
-    // Graph execution path not yet wired through the scheduler — see the
-    // detailed checklist in the function header comment above.
-    return -4;
+    const auto & model   = ctx->get_model();
+    const int64_t n_vocab = model.vocab.n_tokens();
+    if (n_vocab <= 0) {
+        return -2;
+    }
+
+    // Scratch buffer for one row of logits per draft step.
+    std::vector<float> scratch_logits((size_t) n_vocab);
+
+    llama_token seed = last_token;
+    int32_t produced = 0;
+
+    for (int32_t k = 0; k < n_draft; ++k) {
+        const int32_t rc = ctx->mtp_graph_compute(seed, scratch_logits.data(), n_vocab);
+        if (rc != 0) {
+            // Bail out — return what we have so far if anything.
+            return produced > 0 ? produced : rc;
+        }
+
+        // Greedy argmax over the produced logits row.
+        int64_t      best_idx = 0;
+        float        best_val = scratch_logits[0];
+        for (int64_t v = 1; v < n_vocab; ++v) {
+            const float val = scratch_logits[v];
+            if (val > best_val) {
+                best_val = val;
+                best_idx = v;
+            }
+        }
+
+        out_tokens[k] = (llama_token) best_idx;
+        if (out_logits != nullptr) {
+            std::memcpy(out_logits + (size_t) k * (size_t) n_vocab,
+                        scratch_logits.data(),
+                        (size_t) n_vocab * sizeof(float));
+        }
+
+        // Chain: next seed token is the just-sampled argmax. We intentionally
+        // do NOT mutate ctx->mtp_prev_hidden — see correctness note above.
+        seed = (llama_token) best_idx;
+        ++produced;
+    }
+
+    return produced;
 }
 
 //
