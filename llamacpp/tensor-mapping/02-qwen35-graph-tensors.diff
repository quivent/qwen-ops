+        ggml_tensor * mtp_logits = build_mtp_head(prev_hidden, tok_embed, il_mtp, nullptr);
+        cb(mtp_logits, "result_output", -1);
+        res->t_logits = mtp_logits;
+
+        ggml_build_forward_expand(gf, mtp_logits);
+        return;
+    }
