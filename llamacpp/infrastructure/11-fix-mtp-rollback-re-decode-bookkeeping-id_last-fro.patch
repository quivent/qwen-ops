From: quivent <quivent@users.noreply.github.com>
Date: Wed, 8 Apr 2026 21:39:19 -0400
Subject: [PATCH] =?UTF-8?q?fix(mtp):=20rollback=20re-decode=20bookkeeping?=
 =?UTF-8?q?=20=E2=80=94=20id=5Flast=20from=20tail=20logits?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

After the batched rollback re-decode of [id_last, drafts..., corr], the
old code set id_last = corr. But corr was already written to the cache
as the LAST slot of that batch. The next iteration's verify then wrote
corr a SECOND time at position n_past+n_commit, duplicating the token
and shifting every subsequent position by one. The model saw garbage
context and produced "1. 2. 3. ... 1000000" digit-loops within ~10
tokens of any rejection.

Fix mirrors the accept-all branch: read the tail logits of the
re-decoded batch and use argmax as id_last. n_past advances by exactly
n_commit; no double-write.

Also adds env-gated debug instrumentation that helped find the bug:
  MTP_DEBUG_SLOT0=1   dump top-5 slot-0 logits per verify (first 40)
  MTP_ROLLBACK_T1=1   re-decode rollback as N x T=1 instead of one T=N
  MTP_FULL_SEQRM=1    use full seq_rm instead of seq_rm_attn_only

Confirmed: K=1 vanilla output now matches plain decode structurally on
the planets / photosynthesis / fibonacci / haiku / translate prompts.
K=1 spec mean throughput on Qwen3.5-27B Q4_K_M (M4 Max): 7.64 tok/s
(plain decode: 17.90 tok/s).

---
 examples/mtp-speculative/mtp-speculative.cpp | 90 +++++++++++++++++++-
 1 file changed, 87 insertions(+), 3 deletions(-)

diff --git a/examples/mtp-speculative/mtp-speculative.cpp b/examples/mtp-speculative/mtp-speculative.cpp
index 785421671..95cd09216 100644
--- a/examples/mtp-speculative/mtp-speculative.cpp
+++ b/examples/mtp-speculative/mtp-speculative.cpp
@@ -491,6 +491,28 @@ int main(int argc, char ** argv) {
                 break;
             }
             common_speculative_mtp_note_forward_pass(spec);
+            if (getenv("MTP_DEBUG_SLOT0") != nullptr) {
+                static int dump_iter_ar = 0;
+                if (dump_iter_ar < 40) {
+                    const float * l0 = llama_get_logits_ith(ctx_tgt, 0);
+                    int top5[5] = {-1,-1,-1,-1,-1};
+                    float tv[5]  = {-1e30f,-1e30f,-1e30f,-1e30f,-1e30f};
+                    for (int v = 0; v < n_vocab; ++v) {
+                        float x = l0[v];
+                        for (int k = 0; k < 5; ++k) {
+                            if (x > tv[k]) {
+                                for (int j = 4; j > k; --j) { tv[j]=tv[j-1]; top5[j]=top5[j-1]; }
+                                tv[k]=x; top5[k]=v; break;
+                            }
+                        }
+                    }
+                    fprintf(stderr, "[SLOT0 AR   iter=%d n_past=%d id_last=%d] ",
+                            dump_iter_ar, (int)n_past, (int)id_last);
+                    for (int k=0;k<5;++k) fprintf(stderr,"(%d,%.4f) ", top5[k], tv[k]);
+                    fprintf(stderr,"\n");
+                    dump_iter_ar++;
+                }
+            }
             n_past += 1;
 
             const llama_token nt = argmax_logits(llama_get_logits_ith(ctx_tgt, 0));
@@ -728,6 +750,30 @@ int main(int argc, char ** argv) {
             break;
         }
         common_speculative_mtp_note_forward_pass(spec);
+        // DIVERGENCE DUMP: slot 0 top-5 for the K+1 verify batch.
+        if (getenv("MTP_DEBUG_SLOT0") != nullptr) {
+            static int dump_iter = 0;
+            if (dump_iter < 40) {
+                const float * l0 = llama_get_logits_ith(ctx_tgt, 0);
+                int top5[5] = {-1,-1,-1,-1,-1};
+                float tv[5]  = {-1e30f,-1e30f,-1e30f,-1e30f,-1e30f};
+                for (int v = 0; v < n_vocab; ++v) {
+                    float x = l0[v];
+                    for (int k = 0; k < 5; ++k) {
+                        if (x > tv[k]) {
+                            for (int j = 4; j > k; --j) { tv[j]=tv[j-1]; top5[j]=top5[j-1]; }
+                            tv[k]=x; top5[k]=v; break;
+                        }
+                    }
+                }
+                fprintf(stderr, "[SLOT0 SPEC iter=%d n_past=%d id_last=%d n_drafted=%d d0=%d] ",
+                        dump_iter, (int)n_past, (int)id_last, (int)n_drafted,
+                        n_drafted>0 ? (int)drafts[0] : -1);
+                for (int k=0;k<5;++k) fprintf(stderr,"(%d,%.4f) ", top5[k], tv[k]);
+                fprintf(stderr,"\n");
+                dump_iter++;
+            }
+        }
 
         // Step 4: greedy verification.
         //
@@ -806,7 +852,13 @@ int main(int argc, char ** argv) {
                     snap = nullptr;
                     break;
                 }
-                if (!llama_memory_seq_rm_attn_only(ctx_tgt, 0, n_past, -1)) {
+                if (getenv("MTP_FULL_SEQRM") != nullptr) {
+                    // DEBUG: full seq_rm trims BOTH attn and recurrent. Recurrent
+                    // half was already restored from snapshot, so this is a
+                    // double-trim — used to test whether attn-only is missing
+                    // some bookkeeping the recurrent path needs.
+                    llama_memory_seq_rm(mem_tgt, 0, n_past, -1);
+                } else if (!llama_memory_seq_rm_attn_only(ctx_tgt, 0, n_past, -1)) {
                     LOG_ERR("%s: attn-only seq_rm failed\n", __func__);
                     llama_memory_release_snapshot(snap);
                     snap = nullptr;
@@ -854,6 +906,24 @@ int main(int argc, char ** argv) {
                 // is bit-identical to N sequential T=1 decodes. This
                 // eliminates the N-way per-token graph dispatch overhead
                 // that previously dominated the K=1 rollback cost.
+                bool rollback_ok = true;
+                if (getenv("MTP_ROLLBACK_T1") != nullptr) {
+                    // DEBUG: re-decode token-by-token at T=1 to eliminate ALL
+                    // T>1 batch numerical paths. If this fixes output quality,
+                    // the bug is in the T=N rollback path.
+                    for (int32_t i = 0; i < n_commit && rollback_ok; ++i) {
+                        verify_batch.n_tokens     = 1;
+                        verify_batch.token[0]     = commit_toks[i];
+                        verify_batch.pos[0]       = n_past + i;
+                        verify_batch.n_seq_id[0]  = 1;
+                        verify_batch.seq_id[0][0] = 0;
+                        verify_batch.logits[0]    = (i == n_commit - 1) ? 1 : 0;
+                        if (llama_decode(ctx_tgt, verify_batch) != 0) {
+                            LOG_ERR("%s: rollback T=1 step %d failed\n", __func__, i);
+                            rollback_ok = false;
+                        }
+                    }
+                } else {
                 verify_batch.n_tokens = n_commit;
                 for (int32_t i = 0; i < n_commit; ++i) {
                     verify_batch.token[i]     = commit_toks[i];
@@ -862,7 +932,6 @@ int main(int argc, char ** argv) {
                     verify_batch.seq_id[i][0] = 0;
                     verify_batch.logits[i]    = (i == n_commit - 1) ? 1 : 0;
                 }
-                bool rollback_ok = true;
                 {
                     // Use chunking path (no scoped_force_ar) for minimum
                     // dispatch overhead. Numerical divergence from pure AR
@@ -874,14 +943,29 @@ int main(int argc, char ** argv) {
                         rollback_ok = false;
                     }
                 }
+                } // end batched else
                 if (!rollback_ok) {
                     llama_memory_release_snapshot(snap);
                     snap = nullptr;
                     break;
                 }
                 common_speculative_mtp_note_forward_pass(spec);
+                // FIX: corr is already committed to the cache by the re-decode
+                // above (it was the last token of commit_toks). The next
+                // iteration's verify will write id_last into the cache at
+                // position n_past+n_commit, so id_last must be the NEXT
+                // unwritten token — not corr (which is already at n_past+
+                // n_commit-1). Mirrors the accept-all branch below.
+                {
+                    const float * tail_logits =
+                        llama_get_logits_ith(ctx_tgt, n_commit - 1);
+                    const llama_token nt = argmax_logits(tail_logits);
+                    generated.push_back(nt);
+                    common_speculative_mtp_note_committed(spec, 1);
+                    LOG("%s", common_token_to_piece(ctx_tgt, nt).c_str());
+                    id_last = nt;
+                }
                 n_past  += n_commit;
-                id_last = corr;
                 tokens_since_refresh += (n_accepted + 1);
             }
         } else {
