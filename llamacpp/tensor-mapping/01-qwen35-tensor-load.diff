+    def __init__(self, *args, **kwargs):
+        super().__init__(*args, **kwargs)
+        # Extend block_count by the number of MTP predict layers so the tensor_map
+        # has slots for the trailing MTP block (blk.<n_base>.* / blk.<n_base>.nextn.*).
