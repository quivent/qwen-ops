                     }
                 } break;
             case LLM_ARCH_QWEN35MOE:
@@ -8129,6 +8142,20 @@ bool llama_model::has_tensor_overrides() const {
     return pimpl->has_tensor_overrides;
 }
 
+bool llama_model::has_mtp_head() const {
+    if (hparams.nextn_predict_layers == 0 || layers.empty()) {
+        return false;
+    }
+    // MTP tensors live on the last nextn_predict_layers; eh_proj is the definitive marker
+    const uint32_t n_layer = hparams.n_layer;
+    for (uint32_t i = n_layer - hparams.nextn_predict_layers; i < n_layer; ++i) {
+        if (layers[i].nextn.eh_proj == nullptr) {
+            return false;
+        }
+    }
+    return true;
+}
+
 const ggml_tensor * llama_model::get_tensor(const char * name) const {
     auto it = std::find_if(tensors_by_name.begin(), tensors_by_name.end(),
             [name](const std::pair<std::string, ggml_tensor *> & it) {
@@ -8873,6 +8900,10 @@ int32_t llama_model_n_embd(const llama_model * model) {
     return model->hparams.n_embd;
 }
 
+bool llama_model_has_mtp_head(const llama_model * model) {
+    return model && model->has_mtp_head();
+}
+
 int32_t llama_model_n_embd_inp(const llama_model * model) {
     return model->hparams.n_embd_inp();
 }
