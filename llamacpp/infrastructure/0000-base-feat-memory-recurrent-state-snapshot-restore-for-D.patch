diff --git a/include/llama.h b/include/llama.h
index abcd6bd04..f0bc95cff 100644
--- a/include/llama.h
+++ b/include/llama.h
@@ -807,6 +807,54 @@ extern "C" {
             ggml_backend_sched_eval_callback callback,
             void * user_data);
 
+    //
+    // Recurrent-state rollback (split-recurrence speculative decoding)
+    //
+    // Opaque handle representing a captured snapshot of the DeltaNet / SSM
+    // recurrent state (conv_state + rnn_state per layer). Intended for hybrid
+    // models such as Qwen3-Next where the recurrent state cannot be trimmed
+    // like a KV cache, so speculative decoding needs a cheap rollback path.
+    //
+    // Typical usage:
+    //     llama_memory_recurrent_snapshot_t snap = NULL;
+    //     llama_memory_snapshot_recurrent(ctx, &snap);
+    //     // ... run speculative decode ...
+    //     if (rejected) {
+    //         llama_memory_restore_recurrent(ctx, snap);
+    //         llama_memory_seq_rm(mem, seq_id, accepted_pos, -1);
+    //     }
+    //     llama_memory_release_snapshot(snap);
+    //
+    // Only the (small) recurrent state is copied. KV-cache rollback for
+    // attention layers in hybrid models is handled separately via the
+    // existing llama_memory_seq_rm() API.
+
+    typedef struct llama_memory_recurrent_snapshot * llama_memory_recurrent_snapshot_t;
+
+    // Capture the current recurrent state into a newly allocated snapshot.
+    // Returns 0 on success, negative on failure. On success, *out_handle
+    // points to a snapshot that must be freed with llama_memory_release_snapshot().
+    LLAMA_API int32_t llama_memory_snapshot_recurrent(
+            struct llama_context * ctx,
+            llama_memory_recurrent_snapshot_t * out_handle);
+
+    // Restore the recurrent state from a previously captured snapshot.
+    // Returns 0 on success, negative on failure (e.g. shape mismatch).
+    // Does NOT touch the KV cache — caller must use llama_memory_seq_rm()
+    // to rewind attention state for the same sequence/position range.
+    LLAMA_API int32_t llama_memory_restore_recurrent(
+            struct llama_context * ctx,
+            llama_memory_recurrent_snapshot_t handle);
+
+    // Free a snapshot returned by llama_memory_snapshot_recurrent().
+    // Safe to call with NULL.
+    LLAMA_API void llama_memory_release_snapshot(
+            llama_memory_recurrent_snapshot_t handle);
+
+    // Return the number of bytes held by a snapshot (diagnostic).
+    LLAMA_API size_t llama_memory_snapshot_size(
+            llama_memory_recurrent_snapshot_t handle);
+
     //
     // State / sessions
     //
