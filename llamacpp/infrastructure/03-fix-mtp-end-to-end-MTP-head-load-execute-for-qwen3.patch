     if (res->t_mtp_pos_zero_in != nullptr) {
-        const int32_t zero = 0;
-        ggml_backend_tensor_set(res->t_mtp_pos_zero_in, &zero, 0, sizeof(zero));
+        const size_t zbytes = ggml_nbytes(res->t_mtp_pos_zero_in);
+        std::vector<int32_t> zeros(zbytes / sizeof(int32_t), 0);
+        ggml_backend_tensor_set(res->t_mtp_pos_zero_in, zeros.data(), 0, zbytes);
     }
 
     const auto status = graph_compute(gf, /*batched=*/false);
