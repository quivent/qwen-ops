+    # ------------------------------------------------------------------
+    # Recurrent-rollback API
+    # ------------------------------------------------------------------
+
+    def setup_rollback_manager(self, max_positions: int = 6):
+        """Create and attach a GDNRollbackManager to all GDN layers.
+
+        Call once during model init when speculative decoding is enabled.
+        The manager is shared across all GDN layers.
+
+        Args:
+            max_positions: Maximum speculative positions to checkpoint
+                (typically num_speculative_tokens + 1).
+        """
+        from vllm.model_executor.layers.mamba.gdn_linear_attn import (
+            GDNRollbackManager,
+        )
+        self._rollback_manager = GDNRollbackManager(
+            max_positions=max_positions)
+        self._gdn_layers: list[tuple[int, object]] = []
+        for layer in self.layers:
+            if (hasattr(layer, 'layer_type')
+                    and layer.layer_type == "linear_attention"):
+                gdn = layer.linear_attn
+                gdn._rollback_manager = self._rollback_manager
+                self._gdn_layers.append((gdn._layer_abs_idx, gdn))
+
+    def begin_verification(self):
+        """Enable checkpoint saving for the upcoming verify forward."""
+        if hasattr(self, '_rollback_manager'):
+            self._rollback_manager.begin_verification()
+
+    def end_verification(self):
+        """Disable checkpoints and release memory."""
+        if hasattr(self, '_rollback_manager'):
+            self._rollback_manager.end_verification()
+
+    def rollback_gdn_state(self, position: int, state_index: int):
+        """Restore GDN state across all layers to after token *position*.
+
+        Call when MTP verification rejects at position K::
+
+            model.rollback_gdn_state(K - 1, state_index=slot_id)
+
+        This restores both conv_state and ssm_state for all 48 GDN
+        layers in O(num_layers) time (~0.15 ms total).
+
+        Args:
+            position: Target position (-1 = pre-verification).
+            state_index: Cache slot for the request being rolled back.
+        """
+        if not hasattr(self, '_rollback_manager'):
+            raise RuntimeError(
+                "Rollback manager not initialized. "
+                "Call setup_rollback_manager() first.")
+        self._rollback_manager.restore_state(
+            position, self._gdn_layers, state_index)
+
+    def get_rollback_manager(self):
+        """Return the rollback manager, or None if not set up."""
+        return getattr(self, '_rollback_manager', None)
