diff --git a/include/llama.h b/include/llama.h
index f0bc95cff..325c3926a 100644
--- a/include/llama.h
+++ b/include/llama.h
@@ -1080,6 +1080,42 @@ extern "C" {
     // returns NULL for invalid ids.
     LLAMA_API float * llama_get_logits_ith(struct llama_context * ctx, int32_t i);
 
+    //
+    // Multi-Token Prediction (MTP / NextN) draft API
+    //
+    // Runs the per-model MTP head autoregressively for `n_draft` steps,
+    // producing `n_draft` greedy draft tokens that follow `last_token` at
+    // the current decoder hidden state.
+    //
+    // Preconditions:
+    //   - The model must carry MTP weights (see llama_model_has_mtp_head()).
+    //   - A successful llama_decode() must have been performed immediately
+    //     prior so that the last hidden state is available in the context.
+    //
+    // Arguments:
+    //   ctx         - context bound to a model with an MTP head
+    //   last_token  - the most recently emitted / seed token (id)
+    //   n_draft     - number of draft tokens to generate (>= 1)
+    //   out_tokens  - caller-allocated buffer of length n_draft (token ids)
+    //   out_logits  - optional caller-allocated buffer of length
+    //                 n_draft * n_vocab to receive the per-step logits
+    //                 (may be NULL)
+    //
+    // Returns 0 on success, negative on failure:
+    //   -1  model has no MTP head
+    //   -2  invalid arguments
+    //   -3  no hidden state available (llama_decode must run first)
+    //   -4  graph compute failure
+    LLAMA_API int32_t llama_mtp_draft(
+            struct llama_context * ctx,
+                     llama_token   last_token,
+                         int32_t   n_draft,
+                     llama_token * out_tokens,
+                           float * out_logits);
+
+    // Returns true if the loaded model has an MTP (NextN) head usable with llama_mtp_draft().
+    LLAMA_API bool llama_model_has_mtp_head(const struct llama_model * model);
+
     // Get all output token embeddings.
     // when pooling_type == LLAMA_POOLING_TYPE_NONE or when using a generative model,
     // the embeddings for which llama_batch.logits[i] != 0 are stored contiguously
