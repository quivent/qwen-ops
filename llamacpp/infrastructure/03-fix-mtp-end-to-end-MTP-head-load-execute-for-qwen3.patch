@@ -3647,10 +3647,14 @@ int32_t llama_context::mtp_graph_compute(llama_token seed_token, float * out_log
         ggml_backend_tensor_set(res->t_mtp_prev_hidden_in, mtp_prev_hidden.data(), 0, want_bytes);
     }
 
-    // Upload the RoPE position-zero input (a single int32 zero).
+    // Upload the RoPE position-zero input. MRoPE (Qwen3.5) expects 4 int32s
+    // per token (one per rope section). We allocated the tensor as length 4
+    // in build_mtp_head; size-agnostic zero fill covers both that layout and
