diff --git a/src/llama-context.cpp b/src/llama-context.cpp
index d1a418ffa..b5d29a8fc 100644
--- a/src/llama-context.cpp
+++ b/src/llama-context.cpp
@@ -3484,6 +3484,45 @@ int32_t llama_decode(
     return ret;
 }
 
+//
+// Multi-Token Prediction (MTP / NextN) draft
+//
+// This is a thin public-API entry point that validates inputs and delegates
+// to the model's MTP head graph builder (see llm_build_qwen3next::build_mtp_head).
+//
+// The graph builder is in place and matches the MLX reference; what this
+// stub currently does NOT do is run the builder K times through the scheduler
+// and read back logits. That requires adding a new llm_graph_type for
+// MTP-only forward passes plus a small allocator loop in llama_context.
+// Until that lands, the entry point returns a diagnostic so downstream
+// callers can detect whether MTP is available and fall back to stock decode.
+//
+// TODO(mtp): wire up through process_ubatch with a new LLM_GRAPH_TYPE_MTP.
+int32_t llama_mtp_draft(
+        struct llama_context * ctx,
+                 llama_token   last_token,
+                     int32_t   n_draft,
+                 llama_token * out_tokens,
+                       float * out_logits) {
+    GGML_UNUSED(last_token);
+    GGML_UNUSED(out_logits);
+
+    if (ctx == nullptr || out_tokens == nullptr || n_draft <= 0) {
+        return -2;
+    }
+
+    if (!llama_model_has_mtp_head(&ctx->get_model())) {
+        return -1;
+    }
+
+    // Graph execution path not yet wired through the scheduler.
+    // The graph BUILDER is implemented (see src/models/qwen3next.cpp
+    // build_mtp_head) and the MTP weights are loaded — the remaining work
+    // is a new llm_graph_type + process_ubatch route. Until then, return -4
+    // to signal callers that MTP execution is unavailable.
+    return -4;
+}
+
