 src/CMakeLists.txt            |   1 +
 src/llama-context.cpp         |  78 ++++++++++++++++++++++
 src/llama-memory-snapshot.cpp | 121 ++++++++++++++++++++++++++++++++++
 src/llama-memory-snapshot.h   |  65 ++++++++++++++++++
 src/models/qwen3next.cpp      |   8 +++
 6 files changed, 321 insertions(+)
 create mode 100644 src/llama-memory-snapshot.cpp
